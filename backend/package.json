{
  "name": "fin-tweet-backend",
  "version": "1.0.0",
  "description": "Node.js + Express + MongoDB backend for FinTweet.",
  "main": "src/index.js",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
